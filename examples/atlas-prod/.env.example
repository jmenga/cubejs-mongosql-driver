# mongosql-cubejs-driver — production Atlas + AWS IAM
#
# Copy to `.env` and fill in your values. In a real deployment these
# project onto the Cube container via Kubernetes Secrets / SSM Parameter
# Store / external-secrets-operator — never commit a populated `.env`.

# ============================================================================
# Cube driver routing
# ============================================================================
CUBEJS_DB_TYPE=mongosql

# ============================================================================
# MongoDB connection — AWS IAM (no static creds in this string)
# ============================================================================
# - mongodb+srv:// resolves the cluster's hostname via DNS SRV (Atlas standard)
# - authMechanism=MONGODB-AWS delegates auth to the AWS credential chain
# - authSource=$external is required by Atlas for IAM auth
# - retryWrites and w=majority are Atlas best practice
CUBEJS_DB_URI=mongodb+srv://cluster0.abcde.mongodb.net/?authMechanism=MONGODB-AWS&authSource=%24external&retryWrites=true&w=majority

# Database where __sql_schemas lives (Atlas SQL Interface populates per-DB)
CUBEJS_DB_NAME=example

# ============================================================================
# Schema management — Atlas-managed sampler
# ============================================================================
# `collection` (default) reads __sql_schemas from CUBEJS_DB_NAME
CUBEJS_MONGOSQL_SCHEMA_SOURCE=collection

# Refresh every 5 minutes (production default — don't go lower without
# checking Atlas log volume from the schema-collection reads)
CUBEJS_MONGOSQL_SCHEMA_REFRESH_SEC=300

# Fail-closed: if __sql_schemas can't be loaded on startup, testConnection
# fails and the Cube readiness probe goes red. Recommended for prod.
CUBEJS_MONGOSQL_SCHEMA_FAIL_OPEN=false

# ============================================================================
# Query bounds
# ============================================================================
# 60 s per-query timeout — protects Atlas from runaway aggregations
CUBEJS_MONGOSQL_QUERY_TIMEOUT_MS=60000

# 100 000-row buffer cap. If your pre-agg builds approach this, partition
# more finely (hour vs day, week vs month) before raising the cap.
CUBEJS_MONGOSQL_MAX_ROWS=100000

# ============================================================================
# Cube standard env vars (orthogonal to the driver — set per Cube docs)
# ============================================================================
# CUBEJS_API_SECRET=...         # rotate via SecretsManager / Vault
# CUBEJS_DB_QUERY_CACHE=true
# CUBEJS_LOG_LEVEL=info
# RUST_LOG=mongosql_cubejs_driver=info,info  # tracing-crate filter

# ============================================================================
# AWS — DO NOT SET STATIC AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# ============================================================================
# EKS Pod Identity injects:
#   AWS_CONTAINER_CREDENTIALS_FULL_URI
#   AWS_CONTAINER_AUTHORIZATION_TOKEN_FILE
# automatically. The mongodb Rust crate's MONGODB-AWS provider consumes
# them via the standard AWS credential chain. Setting static creds on top
# overrides Pod Identity and breaks the rotation guarantee.
