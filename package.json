{
  "name": "@effectuate/cubejs-mongosql-driver",
  "version": "1.0.2",
  "description": "Cube.js native data source driver for MongoDB via the MongoSQL translator (Rust + napi-rs). Replacement for the EOL'd BI Connector path.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "name": "cubejs-mongosql-driver-native",
    "package": {
      "name": "@effectuate/cubejs-mongosql-driver"
    },
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-musl",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin"
      ]
    }
  },
  "scripts": {
    "build": "pnpm build:rust && pnpm build:ts",
    "build:rust": "node scripts/build-rust.mjs --release",
    "build:rust:debug": "node scripts/build-rust.mjs",
    "artifacts": "napi artifacts --output-dir artifacts --npm-dir npm",
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "pnpm test:unit && pnpm test:rust",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:rust": "cargo test --workspace",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:cube-e2e": "vitest run --config vitest.cube-e2e.config.ts",
    "test:e2e": "make e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm lint:js && pnpm lint:rust",
    "lint:js": "biome ci .",
    "lint:rust": "cargo fmt --check && cargo clippy --workspace --all-targets -- -D warnings",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules target npm/*/cubejs-mongosql-driver-native.*.node",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "cubejs",
    "cube",
    "cubejs-driver",
    "mongodb",
    "mongosql",
    "atlas",
    "olap",
    "analytics"
  ],
  "author": "Justin Menga <justin.menga@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmenga/cubejs-mongosql-driver.git"
  },
  "homepage": "https://github.com/jmenga/cubejs-mongosql-driver#readme",
  "bugs": {
    "url": "https://github.com/jmenga/cubejs-mongosql-driver/issues"
  },
  "peerDependencies": {
    "@cubejs-backend/base-driver": "^1.6.0",
    "@cubejs-backend/schema-compiler": "^1.6.0"
  },
  "optionalDependencies": {
    "@effectuate/cubejs-mongosql-driver-linux-x64-gnu": "1.0.0",
    "@effectuate/cubejs-mongosql-driver-linux-arm64-gnu": "1.0.0",
    "@effectuate/cubejs-mongosql-driver-linux-x64-musl": "1.0.0",
    "@effectuate/cubejs-mongosql-driver-linux-arm64-musl": "1.0.0",
    "@effectuate/cubejs-mongosql-driver-darwin-x64": "1.0.0",
    "@effectuate/cubejs-mongosql-driver-darwin-arm64": "1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@cubejs-backend/base-driver": "^1.6.26",
    "@cubejs-backend/schema-compiler": "^1.6.26",
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.4"
}
